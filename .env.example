# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=4953
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://tikashop.qzz.io

# ============================================
# Database (MongoDB)
# ============================================
# For docker-compose: use internal hostname "mongodb"
# For external DB: use full connection string
MONGODB_URL=mongodb://admin:password123@mongodb:27017/ecommerce?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=password123

# ============================================
# Cache (Redis)
# ============================================
# For docker-compose: use internal hostname "redis"
# For external Redis: use full connection string
REDIS_URL=redis://redis:6379

# ============================================
# JWT & Authentication
# ============================================
# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=your-access-token-secret-generate-with-openssl-rand-hex-32
REFRESH_TOKEN_SECRET=your-refresh-token-secret-generate-with-openssl-rand-hex-32

# Token expiry times
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# ============================================
# Login Security & Rate Limiting
# ============================================
GLOBAL_API_RATE_LIMIT_MAX_REQUESTS=300
GLOBAL_API_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_FAIL_MAX_ATTEMPTS=5
LOGIN_FAIL_WINDOW_SECONDS=900
LOGIN_FAIL_BLOCK_SECONDS=900

# ============================================
# OTP Configuration
# ============================================
OTP_DIGIT=6
OTP_EXPIRY=10
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_VERIFY_BLOCK_SECONDS=900
VERIFIED_TTL_SECONDS=600

# ============================================
# Email Service (Nodemailer)
# ============================================
# Gmail with App Password (recommended)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop

# Alternative: Generic SMTP
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_SECURE=false

# ============================================
# API Documentation
# ============================================
# Swagger UI available at: /api-docs
# OpenAPI spec at: /api-docs.json

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
# Uncomment for JSON logging (production)
# LOG_FORMAT=json
NOTIFICATION_WORKER_ENABLED=true

# ============================================
# Google OAuth2
# ============================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4953/api/v1/auth/google/callback

# ============================================
# VNPay
# ============================================
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TERMINAL_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:4953/api/v1/payment/vnpay/return
VNPAY_IPN_URL=http://localhost:4953/api/v1/payment/vnpay/ipn

# ============================================
# Docker-specific Settings
# ============================================
# These are typically set by docker-compose.yml or .env file
# Health check endpoint: GET /health
# Liveness endpoint: GET /

# ============================================
# Production Notes
# ============================================
# DO NOT commit secrets to git!
# Use GitHub Secrets for CI/CD deployment
# For local dev: create .env from this template and update values
